```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Build directories
dist/
build/
*.egg-info/
.tox/
.coverage*

# Original rules preserved
*.log
```